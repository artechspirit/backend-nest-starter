    "/api/v1/users": {
      "get": {
        "operationId": "UsersController_listUsers",
        "parameters": [
          {
            "name": "page",
            "required": false,
            "in": "query",
            "description": "Page number",
            "schema": {
              "default": 1,
              "example": 1,
              "allOf": [
                {
                  "$ref": "#/components/schemas/Object"
                }
              ]
            }
          },
          {
            "name": "limit",
            "required": false,
            "in": "query",
            "description": "Items per page (max 100)",
            "schema": {
              "default": 10,
              "example": 10,
              "allOf": [
                {
                  "$ref": "#/components/schemas/Object"
                }
              ]
            }
          },
          {
            "name": "sort",
            "required": false,
            "in": "query",
            "description": "Sort field name",
            "schema": {
              "example": "createdAt",
              "type": "string"
            }
          },
          {
            "name": "order",
            "required": false,
            "in": "query",
            "description": "Sort order",
            "schema": {
              "default": "desc",
              "example": "desc",
              "type": "string",
              "enum": [
                "asc",
                "desc"
              ]
            }
          },
          {
            "name": "search",
            "required": false,
            "in": "query",
            "description": "Search term for name or email",
            "schema": {
              "example": "John",
              "type": "string"
            }
          },
          {
            "name": "status",
            "required": false,
            "in": "query",
            "description": "Filter users by status",
            "schema": {
              "type": "string",
              "enum": [
                "PENDING_VERIFICATION",
                "ACTIVE",
                "INACTIVE",
                "SUSPENDED",
                "DELETED"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Users successfully retrieved"
          },
          "403": {
            "description": "Forbidden (requires users.read permission)"
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "List active users (paginated)",
        "tags": [
          "Users"
        ]
      }
    },
