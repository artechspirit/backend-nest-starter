NODE_ENV=development
APP_NAME=Backend Starterkit
APP_PORT=4000
APP_PREFIX=api/v1
APP_URL=http://localhost:4000
WEB_URL=http://localhost:3000
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/backend_starterkit?schema=public&connection_limit=10&pool_timeout=20"
JWT_ACCESS_SECRET=change_me_access_secret
JWT_ACCESS_EXPIRES_IN=15m

JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_REFRESH_EXPIRES_IN_DAYS=7

COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# S3 / Object Storage
S3_ENDPOINT=
S3_ACCESS_KEY_ID=your_access_key_id
S3_SECRET_ACCESS_KEY=your_secret_access_key
S3_BUCKET_NAME=your_bucket_name
S3_REGION=us-east-1
S3_PUBLIC_URL=

# Mailer / SMTP
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM="Backend Starterkit <noreply@example.com>"